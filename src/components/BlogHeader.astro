---
import { getCanonicalURL, formatDate } from "../util"

export interface Props {
	title: string;
	publishDate: string;
	description?: string;
	listening?: string;
}

let { title, publishDate, description, listening } = Astro.props;
let canonicalURL = getCanonicalURL(Astro);
---
<style>
h1 {
    font-size: 2.5em;
    margin-bottom: 0.2em;
    margin-top: 0.1em;
}

h1 aside {
    font-size: 0.5em;
    line-height: 0.75em;
    opacity: 0.33;
    font-style: italic;
}

h2 {
    margin: 0.2em 0;
    font-size: 1em;
}

h3 {
    margin: 0;
    padding: 0;
    font-size: 0.8em;
}

header {
    padding-bottom: 1em;
    margin-bottom: 1em;
    border-bottom: 1px solid rgba(0,0,0,0.2);
}

a {
    text-decoration: none;
    transition: opacity 0.2s ease-in-out;
    opacity: 0.66;
}
a i {
    display: inline-block;
    font-style: normal;
    width: 1.2em;
}
a:hover, a:focus {
    opacity: 1;
}

</style>

<header>
    <h1 class="title">
        {title}
        {description && <aside>{description}</aside>}
    </h1>
    <h2 class="published"><a href={canonicalURL}><i>🔗</i> posted {formatDate(publishDate)}</a></h2>
    <h2 class="back"><a href="/"><i>🔙</i> back to index</a></h2>
    {listening && <h3 class="listening">{listening}</h3>}
</header>
