---
// Component Imports
import BaseHead from '../components/BaseHead.astro';
// import BlogHeader from '../components/BlogHeader.astro';
// import BlogPostPreview from '../components/BlogPostPreview.astro';

interface MarkdownFrontmatter {
	publishDate: number;
}

let title = 'brianloveswords';
let description = 'thoughts and feelings';
let permalink = 'https://bjb.dev';

// Data Fetching: List all Markdown posts in the repo.

// let allPosts = await Astro.fetchContent('./posts/*.md');
// allPosts = allPosts.sort((a, b) => new Date(b.publishDate).valueOf() - new Date(a.publishDate).valueOf());

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<html lang="en">
	<head>
		<BaseHead {title} {description} {permalink} />
	</head>
	<body>
		<h1>brianloveswords</h1>
		<h2>logs</h2>
		<ul>
			<li><a href="/_/2022-02-16.html">2022-02-16</a>: <em>what I want in a static site generator</em></li>
			<li><a href="/_/2020-12-28.html">2020-12-28</a>: <em>trying out alfred; experimenting with mpd</em></li>
			<li><a href="/_/2020-12-27.html">2020-12-27</a>: <em>automating default browser switching; ugly images redux</em></li>
			<li><a href="/_/2020-12-04.html">2020-12-04</a>: <em>bandcamp friday picks</em></li>
			<li><a href="/_/2020-11-30.html">2020-11-30</a>: <em>what I’m watching, what I’m reading (no computer stuff)</em></li>
			<li><a href="/_/2020-11-25.html">2020-11-25</a>: <em>thinking bout linting</em></li>
			<li><a href="/_/2020-11-24.html">2020-11-24</a>: <em>fonts and legibility, local dev file serving, unison</em></li>
			<li><a href="/_/2020-11-23.html">2020-11-23</a>: <em>keeping images one notch above ugly; placeholders in type driven design</em></li>
			<li><a href="/_/2020-11-22.html">2020-11-22</a>: <em>cats for adoption; code highlighting</em></li>
			<li><a href="/_/2020-11-21.html">2020-11-21</a>: <em>initial commit</em></li>
		</ul>
